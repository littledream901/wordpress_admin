# ================== 运行模式 ==================
# true=开发模式（开启 /docs /redoc /openapi.json、热重载）
# false=生产模式（关闭文档、禁用热重载）
DEBUG=false

# true=热重载 + 单进程；false=生产多 worker 模式
DEV_MODE=false

# ================== 服务绑定 ==================
# Docker 内部绑定地址，通常无需修改
HOST=127.0.0.1
PORT=9999

# 生产模式下的 worker 数量（仅 DEV_MODE=false 时生效）
WORKERS=2

# ================== 安全密钥（必填） ==================
# 生成命令: openssl rand -hex 32
SECRET_KEY=your-secret-key-here

# ================== 默认密码（新用户初始密码，必填） ==================
DEFAULT_PASSWORD=

# ================== CORS 跨域（生产务必配置具体域名） ==================
# 格式: ["https://your-domain.com", "https://www.your-domain.com"]
CORS_ORIGINS=["http://localhost"]

# ================== 数据库配置 ==================
# ┌─────────────────────────────────────────────────────┐
# │ 场景一：Docker Compose 自动创建 MySQL（默认）       │
# │   保持以下配置不变，DB_HOST=db 即可                  │
# │   同时在 docker-compose.yml 中保留 db 服务           │
# ├─────────────────────────────────────────────────────┤
# │ 场景二：使用 1Panel 内置 MySQL 或外部 MySQL          │
# │   1. 将 DB_HOST 改为 1Panel 中 MySQL 容器的 IP       │
# │   2. 手动创建数据库: CREATE DATABASE vue_fastapi_admin│
# │   3. 注释或删除 docker-compose.yml 中的 db 服务      │
# │   4. 删除 MYSQL_ROOT_PASSWORD 行                     │
# ├─────────────────────────────────────────────────────┤
# │ 场景三：SQLite（单机/开发）                          │
# │   DB_ENGINE=sqlite                                   │
# │   DB_SQLITE_PATH=./data/db.sqlite3                   │
# └─────────────────────────────────────────────────────┘

DB_ENGINE=mysql
DB_HOST=db              # Docker 内部服务名，外部 MySQL 改为实际 IP
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=change-me-to-a-strong-password
DB_NAME=vue_fastapi_admin

# MySQL root 密码（仅 Docker Compose 内置 MySQL 使用，外部 MySQL 删除此行）
MYSQL_ROOT_PASSWORD=root-secret-change-me

# PostgreSQL（可选）
# DB_ENGINE=postgres
# DB_HOST=db
# DB_PORT=5432
# DB_USER=admin
# DB_PASSWORD=your-pg-password
# DB_NAME=vue_fastapi_admin

# ================== JWT 配置 ==================
# 访问令牌过期时间（分钟），默认 7 天
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
# 刷新令牌过期时间（分钟），默认 30 天
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=43200

# ================== 限流配置 ==================
# 每分钟最大请求数
RATE_LIMIT_MAX_REQUESTS=100
# 限流窗口（秒）
RATE_LIMIT_WINDOW_SECONDS=60
# Redis 连接（分布式限流，可选）
# 格式: redis://[:password@]host:port/db
# 留空则使用内存限流（多 worker 不共享状态）
REDIS_URL=

# ================== SSL 验证 ==================
# OnePanel API SSL 验证（生产环境建议保持 true）
OP_VERIFY_SSL=true
# WordPress 站点 SSL 验证
WP_VERIFY_SSL=true

# ================== Feed 文件管理 ==================
# Feed 文件下载有效期优先级:
#   1. 站点流水线 → 配置管理 → 默认流水线配置 → feed_expire_days（推荐）
#   2. 以下环境变量（回退值）
FEED_EXPIRE_DAYS=3
# Feed 域名替换默认目标域名（优先级同上）
FEED_DEFAULT_TARGET_DOMAIN=
