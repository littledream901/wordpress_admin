# ================== 运行模式 ==================
# true=开发模式（开启 /docs /redoc /openapi.json、热重载、CORS 允许 localhost）
# false=生产模式（关闭文档、CORS 必须指定具体域名）
DEBUG=false

# ================== 服务绑定 ==================
# 开发模式用 127.0.0.1；生产模式如需对外暴露请改为 0.0.0.0
HOST=127.0.0.1
PORT=9999
# true=热重载 + 单进程；false=生产多 worker 模式
DEV_MODE=false
# 生产模式下的 worker 数量（1 为单进程）
WORKERS=1

# ================== 安全密钥（必填） ==================
# 生成命令: openssl rand -hex 32
SECRET_KEY=your-secret-key-here

# ================== 默认密码（新用户初始密码，必填） ==================
DEFAULT_PASSWORD=

# ================== CORS 跨域（生产务必配置具体域名） ==================
# 格式: ["https://your-domain.com", "https://www.your-domain.com"]
CORS_ORIGINS=["http://localhost"]

# ================== 数据库配置 ==================
# SQLite（默认，适合单机）
DB_ENGINE=sqlite
DB_SQLITE_PATH=./db.sqlite3

# MySQL（生产推荐）
# DB_ENGINE=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=admin
# DB_PASSWORD=your-mysql-password
# DB_NAME=vue_fastapi_admin

# PostgreSQL
# DB_ENGINE=postgres
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_USER=admin
# DB_PASSWORD=your-pg-password
# DB_NAME=vue_fastapi_admin

# ================== JWT 配置 ==================
# 访问令牌过期时间（分钟），默认 7 天
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
# 刷新令牌过期时间（分钟），默认 30 天
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=43200

# ================== 限流配置 ==================
# 每分钟最大请求数
RATE_LIMIT_MAX_REQUESTS=100
# 限流窗口（秒）
RATE_LIMIT_WINDOW_SECONDS=60
# Redis 连接（分布式限流，可选）
# 格式: redis://[:password@]host:port/db
# 留空则使用内存限流（多 worker 不共享状态）
REDIS_URL=
