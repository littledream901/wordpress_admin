# ================== 运行模式 ==================
# true=开发模式（开启 /docs /redoc /openapi.json、热重载）
# false=生产模式（关闭文档、禁用热重载）
DEBUG=false

# true=热重载 + 单进程；false=生产多 worker 模式
DEV_MODE=false

# ================== 服务绑定 ==================
# Docker 内部绑定地址，通常无需修改
HOST=127.0.0.1
PORT=9999

# 生产模式下的 worker 数量（仅 DEV_MODE=false 时生效）
WORKERS=2

# ================== 安全密钥（必填） ==================
# 生成命令: openssl rand -hex 32
SECRET_KEY=your-secret-key-here

# ================== 默认密码（新用户初始密码，必填） ==================
DEFAULT_PASSWORD=
# RESET_ADMIN_PASSWORD=true                  # 首次部署时 deploy.sh init 自动取消注释，重置 admin 密码

# ================== CORS 跨域（生产务必配置具体域名） ==================
# 格式: ["https://your-domain.com", "https://www.your-domain.com"]
CORS_ORIGINS=["http://localhost"]

# ================== 数据库配置 ==================
# MySQL 连接参数
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=change-me-to-a-strong-password
DB_NAME=vue_fastapi_admin

# MySQL root 密码（仅 Docker Compose 内置 MySQL 使用）
MYSQL_ROOT_PASSWORD=root-secret-change-me

# MySQL 端口映射（仅 Docker Compose 内置 MySQL 使用）
# 默认 127.0.0.1:3306，仅允许本机连接。如需外网访问改为 0.0.0.0:3306（不推荐）
# MYSQL_PORT=127.0.0.1:3306

# ================== JWT 配置 ==================
# 访问令牌过期时间（分钟），默认 7 天
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
# 刷新令牌过期时间（分钟），默认 30 天
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=43200

# ================== 限流配置 ==================
# 每分钟最大请求数
RATE_LIMIT_MAX_REQUESTS=100
# 限流窗口（秒）
RATE_LIMIT_WINDOW_SECONDS=60
# Redis 连接（分布式限流，可选）
# 格式: redis://[:password@]host:port/db
# 留空则使用内存限流（多 worker 不共享状态）
REDIS_URL=

# ================== SSL 验证 ==================
# OnePanel API SSL 验证（生产环境建议保持 true）
OP_VERIFY_SSL=true
# WordPress 站点 SSL 验证
WP_VERIFY_SSL=true

# ================== Feed 文件管理 ==================
# Feed 文件下载有效期优先级:
#   1. 站点流水线 → 配置管理 → 默认流水线配置 → feed_expire_days（推荐）
#   2. 以下环境变量（回退值）
FEED_EXPIRE_DAYS=3
# Feed 域名替换默认目标域名（优先级同上）
FEED_DEFAULT_TARGET_DOMAIN=
